{
  "cleanUrls": true,
  "redirects": [
    { "source": "/ufo", "destination": "/ufo/", "permanent": false },
    {
      "source": "/world-cup",
      "has": [{ "type": "host", "value": "provisions.work" }],
      "destination": "https://provisions.soccer/",
      "permanent": true
    },
    {
      "source": "/world-cup/",
      "has": [{ "type": "host", "value": "provisions.work" }],
      "destination": "https://provisions.soccer/",
      "permanent": true
    },
    {
      "source": "/world-cup/the-daily",
      "has": [{ "type": "host", "value": "provisions.work" }],
      "destination": "https://provisions.soccer/daily",
      "permanent": true
    },
    {
      "source": "/world-cup/the-daily/",
      "has": [{ "type": "host", "value": "provisions.work" }],
      "destination": "https://provisions.soccer/daily",
      "permanent": true
    },
    {
      "source": "/world-cup/kit-index",
      "has": [{ "type": "host", "value": "provisions.work" }],
      "destination": "https://provisions.soccer/kits",
      "permanent": true
    },
    {
      "source": "/world-cup/kit-index/",
      "has": [{ "type": "host", "value": "provisions.work" }],
      "destination": "https://provisions.soccer/kits",
      "permanent": true
    },
    {
      "source": "/world-cup/card-generator",
      "has": [{ "type": "host", "value": "provisions.work" }],
      "destination": "https://provisions.soccer/card",
      "permanent": true
    },
    {
      "source": "/world-cup/card-generator/:path*",
      "has": [{ "type": "host", "value": "provisions.work" }],
      "destination": "https://provisions.soccer/card/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/ufo/", "destination": "https://ufo-archive-three.vercel.app" },
    { "source": "/ufo/:path*", "destination": "https://ufo-archive-three.vercel.app/:path*" }
  ]
}
